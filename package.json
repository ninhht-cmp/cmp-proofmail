{
  "name": "cmp-proofmail",
  "version": "1.1.1",
  "description": "CMP Proofmail | A tool for sending personalized bulk emails to sellers, accompanied by proof of store (real photos). It features a Q&A wizard for users and command flags for developers. The tool automatically captures store images, renders templates, and sends emails with throttle/retry/checkpoint mechanisms.",
  "bin": {
    "proofmail": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prestart": "npm run build",
    "start": "node dist/cli/main.js",
    "send": "node dist/cli/main.js",
    "send:auto": "node dist/cli/main.js --auto",
    "predry": "npm run build",
    "dry": "node dist/cli/main.js --auto --dry",
    "prescreenshot": "npm run build",
    "screenshot": "node scripts/screenshot.js",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json}\"",
    "pretest": "npm run build",
    "test": "node --test test/*.test.js",
    "test:experimental": "node --test experimental/*.test.js",
    "pretest:experimental": "npm run build"
  },
  "license": "ISC",
  "engines": {
    "node": ">=20.17.0"
  },
  "packageManager": "npm@11.17.0",
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "imapflow": "^1.4.2",
    "nodemailer": "^9.0.1",
    "p-limit": "^7.3.0",
    "playwright": "^1.61.0",
    "read-excel-file": "^9.2.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
