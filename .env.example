# Copy this file to `.env` and fill it in.
# Detailed guide / Hướng dẫn chi tiết: HUONG-DAN-CAU-HINH-ENV.md

# --- SMTP (required) ---
SMTP_HOST=proXX.emailserver.vn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seller@example.com
SMTP_PASS=

# --- Sender display ---
MAIL_FROM_NAME=Your Company Name
MAIL_FROM_EMAIL=
MAIL_SUBJECT={{from_name}} — Your Equipment Is Now Visible to {{seller_name}} on comacpro.net
MAIL_TEMPLATE=touch
MAIL_TRANSPORT=smtp

# --- Keep a copy of sent mail ---
MAIL_BCC=
IMAP_SAVE_SENT=false
#IMAP_HOST=proXX.emailserver.vn
#IMAP_PORT=993
#IMAP_SECURE=true
#IMAP_USER=seller@example.com
#IMAP_PASS=
#IMAP_SENT_FOLDER=

# --- Send rate (only with --auto) ---
MAILS_PER_HOUR=100

# --- Screenshot ---
SCREENSHOT_CONCURRENCY=4
SHOT_WIDTH=1280
SHOT_HEIGHT=900
SHOT_FULL_PAGE=false
SHOT_EMAIL_WIDTH=720
SHOT_QUALITY=80

# --- Shop URL identity token (optional) ---
# At send time, append a signed SHOP-IDENTITY token to the CTA link
# (e.g. .../seller/<shop>/products?ref=<token>) so a click is attributed to the
# shop that owns the link, regardless of which account the visitor is logged into.
# token = base64url(shop_id) "." HMAC signature; the receiver resolves the shop and
# checks authenticity with readShopToken(token, SHOP_URL_TOKEN_SECRET).
# Leave the secret EMPTY to disable — links then ship unchanged.
SHOP_URL_TOKEN_SECRET=
SHOP_URL_TOKEN_PARAM=ref
